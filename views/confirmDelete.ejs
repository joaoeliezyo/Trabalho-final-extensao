<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Confirmar Exclusão</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include('cabecalho') %>
  
  <div class="container mt-5">
    <div class="row">
      <div class="col-md-6 offset-md-3">
        <div class="card border-danger">
          <div class="card-header bg-danger text-white">
            <h4 class="mb-0">⚠️ Confirmar Exclusão</h4>
          </div>
          <div class="card-body">
            <p class="lead">Tem certeza que deseja excluir este registro?</p>
            <p class="text-muted">Esta ação não pode ser desfeita.</p>
            
            <div class="d-grid gap-2 d-md-flex justify-content-md-center mt-4">
              <form method="POST" action="delete" style="display: inline;">
                <button type="submit" class="btn btn-danger btn-lg">Confirmar Exclusão</button>
              </form>
              <a href="javascript:history.back()" class="btn btn-secondary btn-lg">Cancelar</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('rodape') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

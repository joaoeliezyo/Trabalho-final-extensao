<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - Sistema de Projetos de Extensão</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    .sidebar {
      background-color: var(--dark-green);
      min-height: 100vh;
      padding-top: 20px;
    }
    .sidebar a {
      color: #ecf0f1;
      text-decoration: none;
      display: block;
      padding: 12px 20px;
      border-left: 3px solid transparent;
      transition: all 0.3s ease;
    }
    .sidebar a:hover {
      background-color: rgba(28, 110, 54, 0.3);
      border-left-color: var(--brand);
      color: var(--text-sidebar-active);
    }
    .sidebar a.active {
      background-color: var(--brand);
      border-left-color: var(--brand-600);
      color: white;
    }
    .main-content {
      padding: 30px;
      background-color: var(--bg);
    }
    .card-icon {
      font-size: 2rem;
      margin-bottom: 10px;
    }
    .module-card {
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      cursor: pointer;
      height: 100%;
      background-color: var(--card);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }
    .module-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 12px 24px rgba(28, 110, 54, 0.15);
    }
    .user-info {
      background-color: rgba(28, 110, 54, 0.1);
      color: var(--text);
      padding: 15px 20px;
      margin-bottom: 20px;
      border-radius: var(--radius-sm);
      border-left: 3px solid var(--brand);
    }
    .logo-section {
      text-align: center;
      padding: 15px;
      border-bottom: 1px solid var(--line);
      margin-bottom: 20px;
    }
    .logo-section h5 {
      color: var(--brand);
      margin: 0;
      font-weight: bold;
    }
    .logo-section small {
      color: var(--muted);
    }
    h6.text-muted {
      color: var(--muted) !important;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
  </style>
</head>
<body>
  <div class="container-fluid">
    <div class="row">
      <!-- Sidebar -->
      <nav class="col-md-3 sidebar">
        <div class="logo-section">
          <h5>📊 Sistema de Extensão</h5>
          <small class="text-muted">UNI•CET</small>
        </div>

        <div class="user-info">
          <strong><i class="bi bi-person-circle"></i> <%= usuario %></strong>
          <br>
          <small><%= tipo %></small>
        </div>

        <h6 class="text-muted px-3 mt-4 mb-2">MENU</h6>
        <a href="/logo" class="active"><i class="bi bi-house"></i> Home</a>
        
        <h6 class="text-muted px-3 mt-4 mb-2">CADASTROS</h6>
        <a href="/pessoa"><i class="bi bi-people"></i> Pessoas</a>
        <a href="/curso"><i class="bi bi-book"></i> Cursos</a>
        <a href="/tipo_pessoa"><i class="bi bi-tag"></i> Tipo Pessoa</a>
        <a href="/faixa_etaria"><i class="bi bi-graph-up"></i> Faixa Etária</a>
        <a href="/escolaridade"><i class="bi bi-mortarboard"></i> Escolaridade</a>
        
        <h6 class="text-muted px-3 mt-4 mb-2">PROJETOS</h6>
        <a href="/projeto_extensao"><i class="bi bi-briefcase"></i> Projetos de Extensão</a>
        <a href="/avaliacao_institucional"><i class="bi bi-star"></i> Avaliações</a>
        
        <h6 class="text-muted px-3 mt-4 mb-2">CONFIGURAÇÕES</h6>
        <a href="/tipo_instituicao"><i class="bi bi-building"></i> Tipos de Instituição</a>
        <a href="/instituicao"><i class="bi bi-shop"></i> Instituições</a>
        <a href="/tipo_plano"><i class="bi bi-file-text"></i> Tipos de Plano</a>
        <a href="/publico_alvo"><i class="bi bi-people"></i> Públicos-Alvo</a>
        <a href="/tipo_acao"><i class="bi bi-lightning"></i> Tipos de Ação</a>
        <a href="/linha_programatica"><i class="bi bi-diagram-2"></i> Linhas Programáticas</a>
        <a href="/papel_projeto"><i class="bi bi-person-badge"></i> Papéis do Projeto</a>
        <a href="/local_execucao"><i class="bi bi-geo-alt"></i> Locais de Execução</a>
        
        <h6 class="text-muted px-3 mt-4 mb-2">SISTEMA</h6>
        <a href="/logout"><i class="bi bi-box-arrow-right"></i> Sair</a>
      </nav>

      <!-- Main Content -->
      <main class="col-md-9 main-content">
        <div class="d-flex justify-content-between align-items-center mb-5">
          <div>
            <h1>Bem-vindo ao Sistema!</h1>
            <p class="text-muted">Gerenciador de Projetos de Extensão - UNI•CET</p>
          </div>
          <div>
            <span class="badge bg-info p-2">
              <i class="bi bi-calendar"></i> <%= new Date().toLocaleDateString('pt-BR') %>
            </span>
          </div>
        </div>

        <!-- Cards de Acesso Rápido -->
        <h3 class="mb-4">Acesso Rápido</h3>
        <div class="row mb-5">
          <div class="col-md-4 mb-3">
            <div class="card module-card" style="border-left: 4px solid var(--brand);">
              <div class="card-body text-center">
                <div class="card-icon" style="color: var(--brand);">
                  <i class="bi bi-people-fill"></i>
                </div>
                <h5 class="card-title">Pessoas</h5>
                <p class="card-text text-muted">Gerenciar pessoas do sistema</p>
                <a href="/pessoa" class="btn btn-primary btn-sm">Acessar</a>
              </div>
            </div>
          </div>

          <div class="col-md-4 mb-3">
            <div class="card module-card" style="border-left: 4px solid var(--bs-success);">
              <div class="card-body text-center">
                <div class="card-icon" style="color: var(--bs-success);">
                  <i class="bi bi-briefcase-fill"></i>
                </div>
                <h5 class="card-title">Projetos</h5>
                <p class="card-text text-muted">Gerenciar projetos de extensão</p>
                <a href="/projeto_extensao" class="btn btn-success btn-sm">Acessar</a>
              </div>
            </div>
          </div>

          <div class="col-md-4 mb-3">
            <div class="card module-card" style="border-left: 4px solid var(--bs-warning);">
              <div class="card-body text-center">
                <div class="card-icon" style="color: var(--bs-warning);">
                  <i class="bi bi-star-fill"></i>
                </div>
                <h5 class="card-title">Avaliações</h5>
                <p class="card-text text-muted">Gerenciar avaliações</p>
                <a href="/avaliacao_institucional" class="btn btn-warning btn-sm">Acessar</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Outras Funcionalidades -->
        <h3 class="mb-4">Outras Funcionalidades</h3>
        <div class="row">
          <div class="col-md-6 mb-3">
            <div class="card module-card">
              <div class="card-body">
                <h5 class="card-title"><i class="bi bi-book" style="color: var(--brand);"></i> Cursos</h5>
                <p class="card-text text-muted">Gerenciar cursos disponíveis</p>
                <a href="/curso" class="btn btn-outline-primary btn-sm">Gerenciar</a>
              </div>
            </div>
          </div>

          <div class="col-md-6 mb-3">
            <div class="card module-card">
              <div class="card-body">
                <h5 class="card-title"><i class="bi bi-tag" style="color: var(--brand);"></i> Tipos</h5>
                <p class="card-text text-muted">Gerenciar tipos de pessoas e categorias</p>
                <a href="/tipo_pessoa" class="btn btn-outline-primary btn-sm">Gerenciar</a>
              </div>
            </div>
          </div>

          <div class="col-md-6 mb-3">
            <div class="card module-card">
              <div class="card-body">
                <h5 class="card-title"><i class="bi bi-graph-up" style="color: var(--brand);"></i> Faixa Etária</h5>
                <p class="card-text text-muted">Gerenciar faixas etárias</p>
                <a href="/faixa_etaria" class="btn btn-outline-primary btn-sm">Gerenciar</a>
              </div>
            </div>
          </div>

          <div class="col-md-6 mb-3">
            <div class="card module-card">
              <div class="card-body">
                <h5 class="card-title"><i class="bi bi-mortarboard" style="color: var(--brand);"></i> Escolaridade</h5>
                <p class="card-text text-muted">Gerenciar níveis de escolaridade</p>
                <a href="/escolaridade" class="btn btn-outline-primary btn-sm">Gerenciar</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Módulos de Configuração -->
        <h3 class="mb-4 mt-5">Configurações e Suporte</h3>
        <div class="row">
          <div class="col-md-4 mb-3">
            <div class="card module-card">
              <div class="card-body text-center">
                <div class="card-icon" style="color: var(--brand);">
                  <i class="bi bi-building"></i>
                </div>
                <h5 class="card-title">Tipos de Instituição</h5>
                <a href="/tipo_instituicao" class="btn btn-outline-primary btn-sm">Gerenciar</a>
              </div>
            </div>
          </div>

          <div class="col-md-4 mb-3">
            <div class="card module-card">
              <div class="card-body text-center">
                <div class="card-icon" style="color: var(--brand);">
                  <i class="bi bi-shop"></i>
                </div>
                <h5 class="card-title">Instituições</h5>
                <a href="/instituicao" class="btn btn-outline-primary btn-sm">Gerenciar</a>
              </div>
            </div>
          </div>

          <div class="col-md-4 mb-3">
            <div class="card module-card">
              <div class="card-body text-center">
                <div class="card-icon" style="color: var(--brand);">
                  <i class="bi bi-file-text"></i>
                </div>
                <h5 class="card-title">Tipos de Plano</h5>
                <a href="/tipo_plano" class="btn btn-outline-primary btn-sm">Gerenciar</a>
              </div>
            </div>
          </div>

          <div class="col-md-4 mb-3">
            <div class="card module-card">
              <div class="card-body text-center">
                <div class="card-icon" style="color: var(--bs-info);">
                  <i class="bi bi-people"></i>
                </div>
                <h5 class="card-title">Públicos-Alvo</h5>
                <a href="/publico_alvo" class="btn btn-outline-info btn-sm">Gerenciar</a>
              </div>
            </div>
          </div>

          <div class="col-md-4 mb-3">
            <div class="card module-card">
              <div class="card-body text-center">
                <div class="card-icon" style="color: var(--bs-info);">
                  <i class="bi bi-lightning"></i>
                </div>
                <h5 class="card-title">Tipos de Ação</h5>
                <a href="/tipo_acao" class="btn btn-outline-info btn-sm">Gerenciar</a>
              </div>
            </div>
          </div>

          <div class="col-md-4 mb-3">
            <div class="card module-card">
              <div class="card-body text-center">
                <div class="card-icon" style="color: var(--bs-info);">
                  <i class="bi bi-diagram-2"></i>
                </div>
                <h5 class="card-title">Linhas Programáticas</h5>
                <a href="/linha_programatica" class="btn btn-outline-info btn-sm">Gerenciar</a>
              </div>
            </div>
          </div>

          <div class="col-md-4 mb-3">
            <div class="card module-card">
              <div class="card-body text-center">
                <div class="card-icon" style="color: var(--bs-warning);">
                  <i class="bi bi-person-badge"></i>
                </div>
                <h5 class="card-title">Papéis do Projeto</h5>
                <a href="/papel_projeto" class="btn btn-outline-warning btn-sm">Gerenciar</a>
              </div>
            </div>
          </div>

          <div class="col-md-4 mb-3">
            <div class="card module-card">
              <div class="card-body text-center">
                <div class="card-icon" style="color: var(--bs-danger);">
                  <i class="bi bi-geo-alt"></i>
                </div>
                <h5 class="card-title">Locais de Execução</h5>
                <a href="/local_execucao" class="btn btn-outline-danger btn-sm">Gerenciar</a>
              </div>
            </div>
          </div>

        <!-- Footer -->
        <div class="mt-5 pt-4 border-top text-muted text-center">
          <p><small>Sistema de Gestão de Projetos de Extensão © 2025 - UNI•CET</small></p>
        </div>
      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

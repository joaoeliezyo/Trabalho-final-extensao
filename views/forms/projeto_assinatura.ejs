<%- include('../cabecalho', { titulo: isEdit ? 'Editar Projeto Assinatura' : 'Cadastrar Projeto Assinatura' }) %>

  <% const registro=typeof projeto_assinatura !=='undefined' ? projeto_assinatura : null; %>
    <% const registroId=registro && registro['id']; %>
      <main id="conteudo-principal-form" class="container my-5">
        <section class="card shadow p-4 p-md-5">
          <h1 class="fs-4 fw-bold mb-4 border-bottom pb-3">
            <%= isEdit ? 'Editar projeto assinatura' : 'Cadastrar projeto assinatura' %>
          </h1>
          <form method="POST"
            action="<%= isEdit ? '/projeto_assinatura/' + registroId + '/edit' : '/projeto_assinatura/cadastrar' %>">

            <div class="mb-3">
              <label for="campo-id" class="form-label">Id</label>
              <input id="campo-id" name="id" class="form-control"
                value="<%= registro && registro['id'] != null ? registro['id'] : '' %>" placeholder="Id" <%=isEdit
                ? 'readonly' : '' %>
              >
            </div>

            <div class="mb-3">
              <label for="campo-id_projeto" class="form-label">Id Projeto</label>
              <input id="campo-id_projeto" name="id_projeto" class="form-control"
                value="<%= registro && registro['id_projeto'] != null ? registro['id_projeto'] : '' %>"
                placeholder="Id Projeto" required>
            </div>

            <div class="mb-3">
              <label for="campo-id_pessoa" class="form-label">Id Pessoa</label>
              <input id="campo-id_pessoa" name="id_pessoa" class="form-control"
                value="<%= registro && registro['id_pessoa'] != null ? registro['id_pessoa'] : '' %>"
                placeholder="Id Pessoa" required>
            </div>

            <div class="mb-3">
              <label for="campo-Assinatura" class="form-label">Assinatura</label>
              <input id="campo-Assinatura" name="Assinatura" class="form-control"
                value="<%= registro && registro['Assinatura'] != null ? registro['Assinatura'] : '' %>"
                placeholder="Assinatura" required>
            </div>

            <div class="mb-3">
              <label for="campo-data_hora" class="form-label">Data Hora</label>
              <input id="campo-data_hora" name="data_hora" class="form-control"
                value="<%= registro && registro['data_hora'] != null ? registro['data_hora'] : '' %>"
                placeholder="Data Hora" required>
            </div>

            <div class="mb-3">
              <label for="campo-ordem" class="form-label">Ordem</label>
              <input id="campo-ordem" name="ordem" class="form-control"
                value="<%= registro && registro['ordem'] != null ? registro['ordem'] : '' %>" placeholder="Ordem"
                required>
            </div>
            <div class="d-flex gap-2 mt-4">
              <button type="submit" class="btn btn-primary">
                <%= isEdit ? 'Salvar alteracoes' : 'Cadastrar' %>
              </button>
              <a href="/projeto_assinatura" class="btn btn-secondary">Voltar</a>
            </div>
          </form>

          <% if (isEdit && registroId) { %>
            <form method="POST" action="/projeto_assinatura/<%= registroId %>/delete" class="mt-3">
              <button type="submit" class="btn btn-danger">Excluir</button>
            </form>
            <% } %>
        </section>
      </main>
      <%- include('../rodape') %>
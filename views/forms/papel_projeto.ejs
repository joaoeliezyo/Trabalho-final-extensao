<%- include('../cabecalho') %>

  <div class="container mt-4">
    <div class="row mb-4">
      <div class="col-md-6">
        <h2><i class="bi bi-person-badge"></i> Papel do Projeto</h2>
      </div>
    </div>

    <div class="row">
      <div class="col-md-6">
        <form method="POST"
          action="<%= isEdit ? `/papel_projeto/${papel_projeto.id_papel}/edit` : '/papel_projeto/cadastrar' %>">

          <div class="mb-3">
            <label for="descricao" class="form-label">Descrição</label>
            <input type="text" class="form-control" id="descricao" name="descricao"
              value="<%= papel_projeto.descricao || '' %>" required>
          </div>

          <div class="d-flex gap-2">
            <a href="/papel_projeto" class="btn btn-secondary">
              <i class="bi bi-arrow-left"></i> Voltar
            </a>
            <button type="submit" class="btn btn-success">
              <i class="bi bi-check-circle"></i> Salvar
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <%- include('../rodape') %>
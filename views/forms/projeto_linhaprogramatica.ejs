
<%- include('../cabecalho', { titulo: isEdit ? 'Editar Projeto Linhaprogramatica' : 'Cadastrar Projeto Linhaprogramatica' }) %>

<% const registro = typeof projeto_linhaprogramatica !== 'undefined' ? projeto_linhaprogramatica : null; %>
<% const registroId = registro && registro['id_projeto']; %>
<main id="conteudo-principal-form" class="container my-5">
  <section class="card shadow p-4 p-md-5">
    <h1 class="fs-4 fw-bold mb-4 border-bottom pb-3">
      <%= isEdit ? 'Editar projeto linhaprogramatica' : 'Cadastrar projeto linhaprogramatica' %>
    </h1>
    <form method="POST" action="<%= isEdit ? '/projeto_linhaprogramatica/' + registroId + '/edit' : '/projeto_linhaprogramatica/cadastrar' %>">

      <div class="mb-3">
        <label for="campo-id_projeto" class="form-label">Id Projeto</label>
        <input
          id="campo-id_projeto"
          name="id_projeto"
          class="form-control"
          value="<%= registro && registro['id_projeto'] != null ? registro['id_projeto'] : '' %>"
          placeholder="Id Projeto"
          <%= isEdit ? 'readonly' : '' %>
        >
      </div>

      <div class="mb-3">
        <label for="campo-id_linha" class="form-label">Id Linha</label>
        <input
          id="campo-id_linha"
          name="id_linha"
          class="form-control"
          value="<%= registro && registro['id_linha'] != null ? registro['id_linha'] : '' %>"
          placeholder="Id Linha"
          required
        >
      </div>
      <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary">
          <%= isEdit ? 'Salvar alteracoes' : 'Cadastrar' %>
        </button>
        <a href="/projeto_linhaprogramatica" class="btn btn-secondary">Voltar</a>
      </div>
    </form>

    <% if (isEdit && registroId) { %>
    <form method="POST" action="/projeto_linhaprogramatica/<%= registroId %>/delete" class="mt-3">
      <button type="submit" class="btn btn-danger">Excluir</button>
    </form>
    <% } %>
  </section>
</main>
<%- include('../rodape') %>
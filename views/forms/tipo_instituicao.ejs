<%- include('../cabecalho') %>

<div class="container mt-4">
  <div class="row mb-4">
    <div class="col-md-6">
      <h2><i class="bi bi-building"></i> Tipo de Instituição</h2>
    </div>
  </div>

  <div class="row">
    <div class="col-md-6">
      <form method="POST" action="<%= isEdit ? `/tipo_instituicao/${tipo_instituicao.id_tipo_instituicao}/edit` : '/tipo_instituicao/cadastrar' %>">
        
        <div class="mb-3">
          <label for="descricao" class="form-label">Descrição</label>
          <input type="text" class="form-control" id="descricao" name="descricao" value="<%= tipo_instituicao.descricao || '' %>" required>
        </div>

        <div class="d-flex gap-2">
          <a href="/tipo_instituicao" class="btn btn-secondary" style="display: inline-flex; align-items: center; gap: 6px;">
            <i class="bi bi-arrow-left"></i> Voltar
          </a>
          <button type="submit" class="btn btn-success" style="display: inline-flex; align-items: center; gap: 6px;">
            <i class="bi bi-check-circle"></i> Salvar
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../rodape') %>
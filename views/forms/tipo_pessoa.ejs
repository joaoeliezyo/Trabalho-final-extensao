<%- include('../cabecalho', { titulo: isEdit ? 'Editar Tipo Pessoa' : 'Cadastrar Tipo Pessoa' }) %>

<% const registro = typeof tipo_pessoa !== 'undefined' ? tipo_pessoa : null; %>
<% const registroId = registro && registro['id_tipo_pessoa']; %>

<div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
  <h1 class="h4 mb-0">
    <i class="bi bi-tag"></i>
    <%= isEdit ? 'Editar Tipo de Pessoa' : 'Cadastrar Novo Tipo de Pessoa' %>
  </h1>
</div>

<form method="POST" action="<%= isEdit ? '/tipo_pessoa/' + registroId + '/edit' : '/tipo_pessoa/cadastrar' %>">
  <div class="mb-3">
    <label for="campo-descricao" class="form-label">
      <i class="bi bi-pencil"></i> Descrição
    </label>
    <input
      id="campo-descricao"
      name="descricao"
      type="text"
      class="form-control"
      value="<%= registro && registro['descricao'] != null ? registro['descricao'] : '' %>"
      placeholder="Ex: Professor, Técnico, Aluno..."
      required
    >
    <small class="form-text text-muted">Digite uma descrição para este tipo de pessoa</small>
  </div>

  <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4 pt-3 border-top">
    <a href="/tipo_pessoa" class="btn btn-secondary">
      <i class="bi bi-arrow-left"></i> Voltar
    </a>
    <button type="submit" class="btn btn-primary">
      <i class="bi bi-check-lg"></i> <%= isEdit ? 'Salvar Alterações' : 'Cadastrar' %>
    </button>
  </div>
</form>

<%- include('../rodape') %>
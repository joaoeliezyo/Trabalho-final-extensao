
<%- include('../cabecalho', { titulo: isEdit ? 'Editar Pessoa' : 'Cadastrar Pessoa' }) %>

<% const registro = typeof pessoa !== 'undefined' ? pessoa : null; %>
<% const registroId = registro && registro['id_pessoa']; %>

<div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
  <h1 class="h4 mb-0">
    <i class="bi bi-person"></i>
    <%= isEdit ? 'Editar Pessoa' : 'Cadastrar Nova Pessoa' %>
  </h1>
</div>

<form method="POST" action="<%= isEdit ? '/pessoa/' + registroId + '/edit' : '/pessoa/cadastrar' %>">
  <div class="mb-3">
    <label for="campo-nome" class="form-label">
      <i class="bi bi-person-badge"></i> Nome Completo
    </label>
    <input
      id="campo-nome"
      name="nome"
      type="text"
      class="form-control"
      value="<%= registro && registro['nome'] != null ? registro['nome'] : '' %>"
      placeholder="Ex: João Silva Santos"
      required
    >
    <small class="form-text text-muted">Digite o nome completo da pessoa</small>
  </div>

  <div class="row">
    <div class="col-md-6 mb-3">
      <label for="campo-cpf" class="form-label">
        <i class="bi bi-file-earmark"></i> CPF
      </label>
      <input
        id="campo-cpf"
        name="cpf"
        type="text"
        class="form-control"
        value="<%= registro && registro['cpf'] != null ? registro['cpf'] : '' %>"
        placeholder="000.000.000-00"
        required
      >
    </div>

    <div class="col-md-6 mb-3">
      <label for="campo-telefone" class="form-label">
        <i class="bi bi-telephone"></i> Telefone
      </label>
      <input
        id="campo-telefone"
        name="telefone"
        type="tel"
        class="form-control"
        value="<%= registro && registro['telefone'] != null ? registro['telefone'] : '' %>"
        placeholder="(00) 99999-9999"
        required
      >
    </div>
  </div>

  <div class="mb-3">
    <label for="campo-email" class="form-label">
      <i class="bi bi-envelope"></i> Email
    </label>
    <input
      id="campo-email"
      name="email"
      type="email"
      class="form-control"
      value="<%= registro && registro['email'] != null ? registro['email'] : '' %>"
      placeholder="exemplo@email.com"
      required
    >
  </div>

  <div class="mb-3">
    <label for="campo-id_tipo_pessoa" class="form-label">
      <i class="bi bi-tag"></i> Tipo de Pessoa
    </label>
    <select
      id="campo-id_tipo_pessoa"
      name="id_tipo_pessoa"
      class="form-select"
      required
    >
      <option value="" disabled <%= !(registro && registro['id_tipo_pessoa']) ? 'selected' : '' %>>Selecione um tipo</option>
      <% if (typeof tiposPessoa !== 'undefined' && tiposPessoa && tiposPessoa.length > 0) { %>
        <% tiposPessoa.forEach(t => { %>
          <option value="<%= t.id_tipo_pessoa %>" <%= registro && registro['id_tipo_pessoa'] == t.id_tipo_pessoa ? 'selected' : '' %>>
            <%= t.descricao %>
          </option>
        <% }) %>
      <% } %>
    </select>
    <small class="form-text text-muted">ID do tipo de pessoa (Professor, Aluno, Técnico, etc)</small>
  </div>

  <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4 pt-3 border-top">
    <a href="/pessoa" class="btn btn-secondary">
      <i class="bi bi-arrow-left"></i> Voltar
    </a>
    <button type="submit" class="btn btn-primary">
      <i class="bi bi-check-lg"></i> <%= isEdit ? 'Salvar Alterações' : 'Cadastrar' %>
    </button>
  </div>
</form>

<%- include('../rodape') %>
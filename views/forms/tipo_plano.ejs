<%- include('../cabecalho') %>

<div class="container mt-4">
  <div class="row mb-4">
    <div class="col-md-6">
      <h2><i class="bi bi-file-text"></i> Tipo de Plano</h2>
    </div>
  </div>

  <div class="row">
    <div class="col-md-6">
      <form method="POST" action="<%= isEdit ? `/tipo_plano/${tipo_plano.id_tipo_plano}/edit` : '/tipo_plano/cadastrar' %>">
        
        <div class="mb-3">
          <label for="descricao" class="form-label">Descrição</label>
          <input type="text" class="form-control" id="descricao" name="descricao" value="<%= tipo_plano.descricao || '' %>" required>
        </div>

        <div class="d-flex gap-2">
          <a href="/tipo_plano" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Voltar
          </a>
          <button type="submit" class="btn btn-success">
            <i class="bi bi-check-circle"></i> Salvar
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../rodape') %>
<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Login — UNI•CET</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="./css/styles.css">
</head>
<body class="bg-light d-flex align-items-center justify-content-center vh-100">

  <main id="conteudo-principal-login" class="container">
    <section id="secao-login" class="card shadow p-4 mx-auto" style="max-width:420px;width:100%;">
      <div class="text-center mb-4">
        <img src="./imagens/logo-unicet.png" alt="Logo UNI•CET" class="img-fluid" style="height:60px">
      </div>
      <h1 class="text-center fs-5 fw-bold mb-4" id="titulo-login">Acesso ao Sistema de Extensão</h1>

      <!-- Área para mensagens de feedback de login (recebidas via URL após redirecionamento do BLAC) -->
      <div id="login-feedback-message" class="alert alert-danger d-none" role="alert">
        <!-- Mensagens de erro serão inseridas aqui pelo servidor (ex: "Credenciais inválidas.") -->
      </div>
      
      <form id="formulario-login" method="POST" action="/login">
        <div class="mb-3">
          <label for="campo-usuario" class="form-label">Usuário</label>
          <input id="campo-usuario" name="username" type="text" class="form-control" required placeholder="seu usuário">
        </div>

        <div class="mb-3">
          <label for="campo-senha" class="form-label">Senha</label>
          <input id="campo-senha" name="password" type="password" class="form-control" required>
        </div>

        <div class="d-grid gap-2">
          <button id="botao-entrar" type="submit" class="btn btn-primary btn-lg">
            Entrar
          </button>
        </div>
        
        <!-- Campos ocultos para redirecionamento do BLAC -->
        <input type="hidden" name="redirect_success_professor" value="form.html">
        <input type="hidden" name="redirect_success_admin" value="admin_dashboard.html">
        <input type="hidden" name="redirect_error" value="login.html?erro=Falha no login. Verifique suas credenciais.">
      </form>

      <p class="text-center text-muted small mt-4 mb-0" id="copyright-login">UNI•CET © 2025</p>
    </section>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <!-- O app.js não é mais necessário aqui para o fluxo de login básico BLAC -->
</body>
</html>
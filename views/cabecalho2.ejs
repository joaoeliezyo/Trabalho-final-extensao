<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= typeof titulo !== 'undefined' ? titulo : 'Registro de Extensão - UNICET' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2TkcmfRyVX3pBnMFcV7oQPJkl9QevSCWr3W6A==" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body>
  <header id="cabecalho-professor">
    <nav class="navbar navbar-expand-lg navbar-dark top-navbar-professor">
      <div class="container-fluid">
        <a class="navbar-brand d-flex align-items-center" href="#" id="link-brand-professor">
          <img src="/imagens/logo-unicet.branca.png" alt="Logo UNICET" height="36" class="me-2">
          <span class="fw-bold">Extensão Acadêmica</span>
        </a>
        <ul class="navbar-nav ms-3 me-auto">
          <li class="nav-item"><a class="nav-link" href="/curso/consultas/curso">Cursos</a></li>
          <li class="nav-item"><a class="nav-link" href="/faixa_etaria/consultas/faixa_etaria">Faixa Etária</a></li>
          <li class="nav-item"><a class="nav-link" href="/escolaridade/consultas/escolaridade">Escolaridade</a></li>
          <li class="nav-item"><a class="nav-link" href="/tipo_pessoa/consultas/tipo_pessoa">Tipo de Pessoa</a></li>  
          <li class="nav-item"><a class="nav-link" href="/avaliacao_institucional/consultas/avaliacao_institucional">Avaliação Institucional</a></li>   
        </ul>
        <div class="d-flex align-items-center">
            <span class="navbar-text text-white me-3 d-none d-md-block" 
                  id="professor-info">Bem-vindo(a), Professor(a) <span class="fw-bold">Nome do Professor</span>!</span>
            <form action="/blac/auth/logout" method="POST" class="m-0">
                <button type="submit" id="botao-sair-professor" class="btn btn-outline-light btn-sm">
                    <i class="fas fa-sign-out-alt me-1"></i> Sair
                </button>
                <input type="hidden" name="redirect_success" value="login.html">
            </form>
        </div>
      </div>
    </nav>
  </header>

<%- include('../cabecalho', { titulo: 'Projetos Custo' }) %>

<main id="conteudo-principal-form" class="container my-5">
  <section id="secao-cadastro-projeto" class="card shadow p-4 p-md-5">
    <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
      <i class="bi bi-cash-coin fs-4 me-2"></i>
      <h1 class="fs-4 fw-bold mb-0">Custos do Projeto</h1>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
      <span class="fw-semibold">Inserir novo registro</span>
      <a href="/projeto_custo/forms/projeto_custo" class="btn btn-success btn-sm"><i class="bi bi-plus-circle me-2"></i>Novo custo</a>
    </div>

    <div id="form-feedback-message" class="alert d-none" role="alert"></div>

    <div class="table-responsive">
      <table class="table table-striped table-hover">
        <thead class="table-light">
          <tr>
            <th>ID</th>
            <th>Id Projeto</th>
            <th>Descrição</th>
            <th>Quantidade</th>
            <th>V. Unitário</th>
            <th>Realizado</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (dados && dados.length > 0) { %>
            <% dados.forEach(d => { %>
              <tr>
                <td>
                  <span class="badge bg-secondary"><%= d.Id %></span>
                </td>
                <td><%= d.id_projeto %></td>
                <td><%= d.descricao %></td>
                <td><%= d.quantitativo %></td>
                <td>
                  <span class="badge bg-info">R$ <%= d.valor_unitario %></span>
                </td>
                <td><%= d.realizado ? 'Sim' : 'Não' %></td>
                <td>
                  <a href="/projeto_custo/<%= d.Id %>/edit" class="btn btn-primary btn-sm" title="Editar">
                    <i class="bi bi-pencil"></i>
                  </a>
                  <a href="/projeto_custo/<%= d.Id %>/delete" class="btn btn-danger btn-sm" title="Deletar" onclick="return confirm('Tem certeza que deseja deletar este custo?')">
                    <i class="bi bi-trash"></i>
                  </a>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="7" class="text-center py-4 text-muted">Nenhum registro de custo encontrado.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <div class="mt-3">
      <a href="/logo" class="btn btn-secondary"><i class="bi bi-arrow-left me-2"></i>Voltar</a>
    </div>
  </section>
</main>

<%- include('../rodape') %>

<%- include('../cabecalho', { titulo: 'Consulta de Tipo de Pessoa' }) %>

<div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
  <h1 class="h4 mb-0">
    <i class="bi bi-list"></i> Tipos de Pessoa Cadastrados
  </h1>
  <a href="/tipo_pessoa/forms/tipo_pessoa" class="btn btn-success">
    <i class="bi bi-plus-lg"></i> Novo Tipo de Pessoa
  </a>
</div>

<div id="form-feedback-message" class="alert d-none" role="alert">
</div>

<div class="table-responsive">
  <table class="table table-hover">
    <thead class="table-light">
      <tr>
        <th><i class="bi bi-hash"></i> ID</th>
        <th><i class="bi bi-tag"></i> Descrição</th>
        <th><i class="bi bi-gear"></i> Ações</th>
      </tr>
    </thead>
    <tbody>
      <% dados.forEach(d => { %>
        <tr>
          <td>
            <span class="badge bg-primary"><%= d.id_tipo_pessoa %></span>
          </td>
          <td><%= d.descricao %></td>
          <td>
            <a href="/tipo_pessoa/<%= d.id_tipo_pessoa %>/edit" class="btn btn-primary btn-sm">
              <i class="bi bi-pencil"></i> Editar
            </a>
            <a href="/tipo_pessoa/<%= d.id_tipo_pessoa %>/delete" class="btn btn-danger btn-sm">
              <i class="bi bi-trash"></i> Excluir
            </a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<div class="mt-4">
  <a href="/logo" class="btn btn-secondary">
    <i class="bi bi-arrow-left"></i> Voltar
  </a>
</div>

<%- include('../rodape') %>

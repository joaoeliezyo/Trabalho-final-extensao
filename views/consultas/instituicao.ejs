<%- include('../cabecalho') %>

<div class="container mt-4">
  <div class="row mb-4">
    <div class="col-md-6">
      <h2><i class="bi bi-shop"></i> Instituições</h2>
    </div>
    <div class="col-md-6 text-end">
      <a href="/instituicao/forms/instituicao" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Nova
      </a>
    </div>
  </div>

  <div class="row mb-3">
    <div class="col-md-12">
      <form method="POST" action="/instituicao/filtro" class="d-flex gap-2">
        <input type="text" name="nome" class="form-control" placeholder="Buscar por nome...">
        <button type="submit" class="btn btn-outline-secondary">
          <i class="bi bi-search"></i> Buscar
        </button>
      </form>
    </div>
  </div>

  <div class="table-responsive">
    <table class="table table-hover">
      <thead class="table-dark">
        <tr>
          <th><i class="bi bi-hash"></i> ID</th>
          <th><i class="bi bi-shop"></i> Nome</th>
          <th><i class="bi bi-tag"></i> Sigla</th>
          <th><i class="bi bi-gear"></i> Ações</th>
        </tr>
      </thead>
      <tbody>
        <% dados.forEach(item => { %>
          <tr>
            <td><span class="badge bg-secondary"><%= item.id_instituicao %></span></td>
            <td><%= item.nome %></td>
            <td><%= item.sigla %></td>
            <td>
              <a href="/instituicao/<%= item.id_instituicao %>/edit" class="btn btn-sm btn-warning">
                <i class="bi bi-pencil"></i>
              </a>
              <form method="POST" action="/instituicao/<%= item.id_instituicao %>/delete" style="display: inline;">
                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Tem certeza?')">
                  <i class="bi bi-trash"></i>
                </button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../rodape') %>

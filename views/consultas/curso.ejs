<%- include('../cabecalho', { titulo: 'Cursos' }) %>

<main id="conteudo-principal-form" class="container my-5">
  <section id="secao-cadastro-projeto" class="card shadow p-4 p-md-5">
    <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
      <i class="bi bi-book fs-4 me-2"></i>
      <h1 class="fs-4 fw-bold mb-0">Cursos cadastrados</h1>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
      <span class="fw-semibold">Inserir novo registro</span>
      <a href="/curso/forms/curso" class="btn btn-success btn-sm"
        ><i class="bi bi-plus-circle me-2"></i>Novo curso</a
      >
    </div>

    <div id="form-feedback-message" class="alert d-none" role="alert"></div>

    <div class="table-responsive">
      <table class="table table-striped table-hover">
        <thead class="table-light">
          <tr>
            <th>ID</th>
            <th>Nome Curso</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (dados && dados.length) { %> <% dados.forEach(d => { %>
          <tr>
            <td>
              <span class="badge bg-secondary"><%= d.id_curso %></span>
            </td>
            <td><%= d.nome_curso %></td>
            <td>
              <a
                href="/curso/<%= d.id_curso %>/edit"
                class="btn btn-primary btn-sm"
                title="Editar"
              >
                <i class="bi bi-pencil"></i>Editar
              </a>
              <a
                href="/curso/<%= d.id_curso %>/delete"
                class="btn btn-danger btn-sm"
                title="Deletar"
                onclick="return confirm('Tem certeza?')"
              >
                <i class="bi bi-trash"></i>Deletar
              </a>
            </td>
          </tr>
          <% }) %> <% } else { %>
          <tr>
            <td colspan="3" class="text-center py-4 text-muted">
              Nenhum curso encontrado.
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <div class="mt-3">
      <a href="/logo" class="btn btn-secondary"
        ><i class="bi bi-arrow-left me-2"></i>Voltar</a
      >
    </div>
  </section>
</main>

<%- include('../rodape') %>

<%- include('../cabecalho') %>

<div class="container mt-4">
  <div class="row mb-4">
    <div class="col-md-6">
      <h2><i class="bi bi-building"></i> Tipos de Instituição</h2>
    </div>
    <div class="col-md-6 text-end">
      <a href="/tipo_instituicao/forms/tipo_instituicao" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Novo
      </a>
    </div>
  </div>

  <div class="row mb-3">
    <div class="col-md-12">
      <form method="POST" action="/tipo_instituicao/filtro" class="d-flex gap-2">
        <input type="text" name="nome" class="form-control" placeholder="Buscar por descrição...">
        <button type="submit" class="btn btn-outline-secondary">
          <i class="bi bi-search"></i> Buscar
        </button>
      </form>
    </div>
  </div>

  <div class="table-responsive">
    <table class="table table-hover">
      <thead class="table-dark">
        <tr>
          <th><i class="bi bi-hash"></i> ID</th>
          <th><i class="bi bi-text-left"></i> Descrição</th>
          <th><i class="bi bi-gear"></i> Ações</th>
        </tr>
      </thead>
      <tbody>
        <% dados.forEach(item => { %>
          <tr>
            <td><span class="badge bg-secondary"><%= item.id_tipo_instituicao %></span></td>
            <td><%= item.descricao %></td>
            <td>
              <a href="/tipo_instituicao/<%= item.id_tipo_instituicao %>/edit" class="btn btn-warning" style="padding: 8px 14px; font-size: 0.95rem; display: inline-flex; align-items: center; gap: 6px;">
                <i class="bi bi-pencil"></i> Editar
              </a>
              <form method="POST" action="/tipo_instituicao/<%= item.id_tipo_instituicao %>/delete" style="display: inline;">
                <button type="submit" class="btn btn-danger" style="padding: 8px 14px; font-size: 0.95rem; display: inline-flex; align-items: center; gap: 6px;" onclick="return confirm('Tem certeza?')">
                  <i class="bi bi-trash"></i> Deletar
                </button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../rodape') %>


<%- include('../cabecalho', { titulo: 'Consulta de Pessoas' }) %>

<div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
  <h1 class="h4 mb-0">
    <i class="bi bi-list"></i> Pessoas Cadastradas
  </h1>
  <a href="/pessoa/forms/pessoa" class="btn btn-success">
    <i class="bi bi-plus-lg"></i> Nova Pessoa
  </a>
</div>

<div id="form-feedback-message" class="alert d-none" role="alert">
</div>

<div class="table-responsive">
  <table class="table table-hover">
    <thead class="table-light">
      <tr>
        <th><i class="bi bi-hash"></i> ID</th>
        <th><i class="bi bi-person-badge"></i> Nome</th>
        <th><i class="bi bi-file-earmark"></i> CPF</th>
        <th><i class="bi bi-envelope"></i> Email</th>
        <th><i class="bi bi-telephone"></i> Telefone</th>
        <th><i class="bi bi-tag"></i> Tipo</th>
        <th><i class="bi bi-gear"></i> Ações</th>
      </tr>
    </thead>
    <tbody>
      <% dados.forEach(d => { %>
        <tr>
          <td>
            <span class="badge bg-primary"><%= d.id_pessoa %></span>
          </td>
          <td><%= d.nome %></td>
          <td><%= d.cpf %></td>
          <td><%= d.email %></td>
          <td><%= d.telefone %></td>
          <td>
            <span class="badge bg-info"><%= d.id_tipo_pessoa %></span>
          </td>
          <td>
            <a href="/pessoa/<%= d.id_pessoa %>/edit" class="btn btn-primary btn-sm">
              <i class="bi bi-pencil"></i> Editar
            </a>
            <a href="/pessoa/<%= d.id_pessoa %>/delete" class="btn btn-danger btn-sm">
              <i class="bi bi-trash"></i> Excluir
            </a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<div class="mt-4">
  <a href="/logo" class="btn btn-secondary">
    <i class="bi bi-arrow-left"></i> Voltar
  </a>
</div>

<%- include('../rodape') %>
  <main id="conteudo-principal-form" class="container my-5">
    <section id="secao-cadastro-projeto" class="card shadow p-4 p-md-5">
      <h1 class="fs-4 fw-bold mb-4 border-bottom pb-3" id="titulo-cadastro-projeto">Cadastrar Novo Projeto de Extensão</h1>

      <div class="d-flex justify-content-between align-items-center mb-3">
        <span class="fw-semibold">Inserir novo registro</span>
        <a href="/avaliacao_participante/forms/avaliacao_participante" class="btn btn-success btn-sm">Nova avaliação</a>
      </div>


      <div id="form-feedback-message" class="alert d-none" role="alert">
        <!-- Mensagens de sucesso ou erro serão inseridas aqui pelo servidor -->
      </div>
<table border="1">
  <thead><tr><th>id_avaliacao_participante</th><th>id_projeto</th><th>data_resposta</th><th>id_faixa</th><th>id_escolaridade</th><th>reside_na_comunidade</th><th>avaliacao_conteudo</th><th>atendeu_expectativas</th><th>facilitadores_acessiveis</th><th>escuta_comunidade</th><th>estrutura_adequada</th><th>sente_mais_capacitado</th><th>contribuicao_pessoal</th><th>descricao_contribuicao</th><th>pretende_aplicar</th><th>motivo_nao_aplicar</th><th>recomendaria</th><th>comentario_positivo</th><th>sugestao_melhoria</th><th>sugestoes_futuras</th><th>consentimento</th><th>assentimento</th></tr></thead>
  <tbody><% dados.forEach(d => { %><tr><td><%= d.id_avaliacao_participante %></td><td><%= d.id_projeto %></td><td><%= d.data_resposta %></td><td><%= d.id_faixa %></td><td><%= d.id_escolaridade %></td><td><%= d.reside_na_comunidade %></td><td><%= d.avaliacao_conteudo %></td><td><%= d.atendeu_expectativas %></td><td><%= d.facilitadores_acessiveis %></td><td><%= d.escuta_comunidade %></td><td><%= d.estrutura_adequada %></td><td><%= d.sente_mais_capacitado %></td><td><%= d.contribuicao_pessoal %></td><td><%= d.descricao_contribuicao %></td><td><%= d.pretende_aplicar %></td><td><%= d.motivo_nao_aplicar %></td><td><%= d.recomendaria %></td><td><%= d.comentario_positivo %></td><td><%= d.sugestao_melhoria %></td><td><%= d.sugestoes_futuras %></td><td><%= d.consentimento %></td><td><%= d.assentimento %></td></tr><% }) %></tbody>
</table>

    </section>
  </main>

  <footer id="rodape-professor" class="text-center py-4 text-muted small mt-5 app-footer">UNI•CET © 2025 — Extensão Acadêmica</footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">

  </script>
  

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pessoas</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include('../cabecalho') %>
  
  <div class="container mt-5">
    <h1 class="mb-4">Pessoas</h1>
    
    <% if (dados && dados.length > 0) { %>
      <div class="table-responsive">
        <table class="table table-striped table-hover">
          <thead class="table-dark">
            <tr>
              <th>ID</th>
              <th>Nome</th>
              <th>CPF</th>
              <th>Email</th>
              <th>Telefone</th>
              <th>Tipo</th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
            <% dados.forEach(pessoa => { %>
              <tr>
                <td><%= pessoa.id_pessoa %></td>
                <td><%= pessoa.nome %></td>
                <td><%= pessoa.cpf %></td>
                <td><%= pessoa.email %></td>
                <td><%= pessoa.telefone %></td>
                <td><%= pessoa.id_tipo_pessoa %></td>
                <td>
                  <a href="/pessoa/edit/<%= pessoa.id_pessoa %>" class="btn btn-sm btn-warning">Editar</a>
                  <a href="/pessoa/delete/<%= pessoa.id_pessoa %>" class="btn btn-sm btn-danger">Excluir</a>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="alert alert-info" role="alert">
        Nenhuma pessoa encontrada.
      </div>
    <% } %>
    
    <div class="mt-4">
      <a href="/pessoa/new" class="btn btn-success">Novo Registro</a>
      <a href="javascript:history.back()" class="btn btn-secondary">Voltar</a>
    </div>
  </div>

  <%- include('../rodape') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

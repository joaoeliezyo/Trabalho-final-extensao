
<%- include('../cabecalho', { titulo: 'Consulta de avaliacao_institucional' }) %>

  <main id="conteudo-principal-form" class="container my-5">
    <section id="secao-cadastro-projeto" class="card shadow p-4 p-md-5">
      <h1 class="fs-4 fw-bold mb-4 border-bottom pb-3">avaliacao_institucional cadastrados novo</h1>
      <div class="d-flex justify-content-between align-items-center mb-3">
        <span class="fw-semibold">Inserir novo registro</span>
        <a class="btn btn-success btn-sm" href="/avaliacao_institucional/forms/avaliacao_institucional">Novo</a>
      </div>
      <div id="form-feedback-message" class="alert d-none" role="alert">
      </div>
      <div class="table-responsive">
        <table class="table table-striped table-hover" border="1">
          <thead class="table-dark">
            <tr><th>id_avaliacao</th><th>id_projeto</th><th>criterios_avaliacao</th><th>metodologia_avaliacao</th><th>forma_apresentacao_relatorio</th>
            <th>Ação</th>
            </tr>            
          </thead>
          <tbody><% dados.forEach(d => { %><tr><td><%= d.id_avaliacao %></td><td><%= d.id_projeto %></td><td><%= d.criterios_avaliacao %></td><td><%= d.metodologia_avaliacao %></td><td><%= d.forma_apresentacao_relatorio %></td>
          <td>
            <a href="/avaliacao_institucional/<%= d.id_avaliacao %>/edit" class="btn btn-primary btn-sm">Editar</a>
            <a href="/avaliacao_institucional/<%= d.id_avaliacao %>/delete" class="btn btn-danger btn-sm">Excluir</a>
          </td>
        </tr><% }) %></tbody>
        </table>
      </div>
      
      <div>
       <!-- <button type="button" class="btn btn-danger btn-sm">Sair</button> -->
        <a href="/logo" class="btn btn-secondary">Voltar</a>
    </div>
    </section>
  </main>
<%- include('../rodape') %>
